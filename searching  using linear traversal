#include <stdio.h>

int main() {
    int arr[] = {10, 20, 30, 40, 50};
    int target = 30;
    int n = sizeof(arr) / sizeof(arr[0]);
    int found = 0;

    // Linear search using traversal
    for(int i = 0; i < n; i++) {
        if(arr[i] == target) {
            found = 1;
            break;
        }
    }

    if(found) {
        printf("Element found! %d",target);
    } else {
        printf("Element not found!\n");
    }

    return 0;
}
